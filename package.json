{
  "name": "lgpd-system-backend",
  "version": "1.0.0",
  "description": "LGPD Compliance System - Backend API",
  "main": "dist/src/app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/app.js",
    "start:cluster": "node dist/cluster.js",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --testPathPattern='tests/unit' --passWithNoTests",
    "test:integration": "jest --testPathPattern='tests/integration' --passWithNoTests --forceExit",
    "test:contract": "jest --testPathPattern='tests/contract' --passWithNoTests --forceExit",
    "test:coverage": "jest --coverage --passWithNoTests",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "db:create-migration": "node-pg-migrate create",
    "db:migrate": "node-pg-migrate up",
    "db:rollback": "node-pg-migrate down",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@supabase/supabase-js": "^2.110.0",
    "docx": "^8.5.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.26.0",
    "jszip": "^3.10.1",
    "node-pg-migrate": "^7.0.0",
    "openai": "^4.24.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.2.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  }
}
